# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Admin credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# GitHub — Personal Access Token with 'repo' scope
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Branch where content JSON files live (usually 'main')
GITHUB_BRANCH=main

# Path inside the repo where src/data/*.json files are located
CONTENT_BASE_PATH=src/data
